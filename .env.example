# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://scis:scis_password@localhost:5432/scis?schema=public&connection_limit=30&pool_timeout=20"
REDIS_URL="redis://localhost:6380"

# ── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
TRUSTED_PROXY=false
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
APP_BASE_URL="http://localhost:4000"

# JWT (generate in prod: openssl rand -base64 64)
JWT_ACCESS_SECRET="dev-access-secret-change-me-please-32chars-min"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-please-32chars-min"
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Service token cho ingest endpoints (gate / canteen sensors)
INGEST_SERVICE_TOKEN="dev-ingest-token-change-me"

# QR signing (HMAC)
QR_HMAC_SECRET="dev-qr-secret-change-me"
QR_TTL_SECONDS=60

# ── Frontend (Vite) ────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
VITE_WS_URL="ws://localhost:4000"
