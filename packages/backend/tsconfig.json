{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2020"],
    "target": "ES2020",
    "module": "ESNext"
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist"]
}
